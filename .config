#
# 小米 R3G OpenWrt 编译配置
# 基于 Lean LEDE
#
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y

# Target: MediaTek Ralink MIPS -> MT7621 -> Xiaomi Mi Router 3G
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-3g=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# -- 基础系统 --
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
# SSL backend: 强制 mbedtls，避免与 openssl 后端冲突
CONFIG_PACKAGE_libustream-mbedtls=y
# CONFIG_PACKAGE_libustream-openssl is not set
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ========================================
# WiFi 驱动 — R3G 无线
# ========================================
# 无线协议栈
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y

# MediaTek MT76 驱动框架
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt7603=y       # MT7603E — 2.4GHz WiFi
CONFIG_PACKAGE_kmod-mt76x2=y       # MT7612E — 5GHz WiFi

# 无线认证/加密 (替代 wpad-mini)
CONFIG_PACKAGE_wpad-basic-wolfssl=y

# ========================================
# USB 共享网络驱动 — 全覆盖
# ========================================

# --- USB Host 控制器 ---
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-usb2=y            # USB 2.0 EHCI
CONFIG_PACKAGE_kmod-usb-ohci=y        # USB 1.1 OHCI
CONFIG_PACKAGE_kmod-usb3=y            # USB 3.0 XHCI (R3G的USB口)

# --- USB 存储 (U盘/硬盘) ---
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y # USB 3.0 UASP 高速模式

# --- USB 网络基础 ---
CONFIG_PACKAGE_kmod-usb-net=y

# --- USB 共享网络: Android 手机 ---
CONFIG_PACKAGE_kmod-usb-net-rndis=y         # Android RNDIS ★
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y     # Android/iOS CDC-ECM ★
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y       # Android CDC-NCM (高速)
CONFIG_PACKAGE_kmod-usb-net-cdc-eem=y       # Android CDC-EEM
CONFIG_PACKAGE_kmod-usb-net-cdc-subset=y    # CDC Subset (兼容老设备)
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y # 华为手机 CDC-NCM

# --- USB 共享网络: iPhone ---
CONFIG_PACKAGE_kmod-usb-net-ipheth=y        # iPhone USB tethering 驱动
CONFIG_PACKAGE_libusbmuxd=y                 # iPhone USB 通信库
CONFIG_PACKAGE_libimobiledevice=y           # iPhone 设备支持库
CONFIG_PACKAGE_usbmuxd=y                    # iPhone USB 多路复用守护进程

# --- USB 4G/5G 上网卡 (Qualcomm CDC-MBIM / QMI / Sierra) ---
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y      # MBIM 协议 (高通 4G/5G 模块)
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y      # QMI 协议 (高通 4G 模块)
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=y # Sierra Wireless 网卡

# --- USB 串口 (4G 网卡 AT 指令 / GPS / 串口模块) ---
CONFIG_PACKAGE_kmod-usb-serial=y            # USB-串口 转换基础
CONFIG_PACKAGE_kmod-usb-serial-option=y     # Option 驱动 (Huawei/ZTE 等)
CONFIG_PACKAGE_kmod-usb-serial-wwan=y       # WWAN 串口
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y   # 高通 QDL/DIAG 串口
CONFIG_PACKAGE_kmod-usb-acm=y               # USB ACM (通用 CDC ACM 设备)

# --- USB 有线网卡 (USB转RJ45) ---
CONFIG_PACKAGE_kmod-usb-net-asix=y          # ASIX AX8817x
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y  # ASIX AX88179 (USB 3.0千兆)
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y       # Realtek RTL8152/8153

# --- USB 模式切换 & 诊断工具 ---
CONFIG_PACKAGE_usb-modeswitch=y             # 4G网卡模式切换
CONFIG_PACKAGE_usbutils=y                   # lsusb 工具

# ========================================
# 文件系统 & U盘自动挂载
# ========================================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ========================================
# 插件
# ========================================
# -- OpenClash（代理上网）--
CONFIG_PACKAGE_luci-app-openclash=y

# -- AdGuard Home（去广告 DNS 拦截）--
CONFIG_PACKAGE_luci-app-adguardhome=y

# ========================================
# 其他实用工具
# ========================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_iperf3=y
